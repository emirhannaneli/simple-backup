// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN or USER
  createdAt    DateTime @default(now())

  @@map("users")
}

model Datasource {
  id              String   @id @default(cuid())
  name            String
  type            String   // MYSQL, POSTGRES, or MONGODB
  host            String
  port            Int
  username        String
  passwordEncrypted String
  databaseName    String
  createdAt       DateTime @default(now())

  jobs            JobDatasource[]

  @@map("datasources")
}

model Job {
  id              String   @id @default(cuid())
  title           String
  cronExpression  String
  destinationPath String
  timezone        String   @default("UTC") // IANA timezone identifier (e.g., "America/New_York", "Europe/Istanbul")
  status          String   @default("IDLE") // IDLE, RUNNING, or ERROR
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  datasources     JobDatasource[]
  backups         Backup[]

  @@map("jobs")
}

model JobDatasource {
  id           String     @id @default(cuid())
  jobId        String
  job          Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  datasourceId String
  datasource   Datasource @relation(fields: [datasourceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([jobId, datasourceId])
  @@map("job_datasources")
}

model Backup {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filename     String
  filePath     String
  size         BigInt
  status       String   // SUCCESS or FAILED
  durationMs   Int
  errorMessage String?
  createdAt    DateTime @default(now())

  @@map("backups")
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(cuid())
  name      String   // Webhook name/description
  url       String
  method    String   @default("POST")
  events    String   // JSON array of event types
  jobIds    String?  // JSON array of job IDs to listen to (null/empty = all jobs)
  headers   String?  // JSON object of custom headers (key-value pairs)
  payload   String?  // JSON string of custom payload template (supports variables like ${jobId}, ${event}, etc.)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  logs      WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id          String   @id @default(cuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String   // JOB_SUCCESS or JOB_FAILURE
  jobId       String?
  jobName     String?
  statusCode  Int?     // HTTP status code from webhook response
  success     Boolean  // Whether the webhook request was successful
  requestBody String   // JSON string of the request payload
  responseBody String? // Response body from webhook endpoint
  errorMessage String? // Error message if request failed
  durationMs   Int?    // Request duration in milliseconds
  createdAt    DateTime @default(now())

  @@map("webhook_logs")
  @@index([webhookId])
  @@index([createdAt])
}

